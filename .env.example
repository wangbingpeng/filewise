# ============================================================
# AI API Configuration (OpenAI-compatible APIs)
# FileWise supports any OpenAI-compatible API provider.
# Uncomment the section for your provider and fill in the key.
# You can also change these settings in the Settings page after startup.
# ============================================================

# --- OpenAI ---
DASHSCOPE_API_KEY=your-openai-api-key
DASHSCOPE_BASE_URL=https://api.openai.com/v1
DASHSCOPE_MODEL=gpt-4o
DASHSCOPE_EMBEDDING_MODEL=text-embedding-3-small

# --- DeepSeek ---
# DASHSCOPE_API_KEY=your-deepseek-api-key
# DASHSCOPE_BASE_URL=https://api.deepseek.com/v1
# DASHSCOPE_MODEL=deepseek-chat
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# --- DashScope (Alibaba Cloud) ---
#DASHSCOPE_API_KEY=your-api-key-here
#DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#DASHSCOPE_MODEL=qwen-plus
#DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
